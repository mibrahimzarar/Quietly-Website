# Maintainer: Ibrahim Zarar <mibrahimzarar@gmail.com>
pkgname=quietlycode
pkgver=1.1.6
pkgrel=1
pkgdesc="Offline-First Local AI IDE powered by llama.cpp and AirLLM"
arch=('x86_64')
url="https://quietlycode.org"
license=('custom')
depends=('libnotify' 'libxtst' 'nss' 'libsecret' 'gtk3' 'libxss')
makedepends=('curl')
options=(!strip)

_gh_api="https://api.github.com/repos/mibrahimzarar/Quietly/releases/latest"
sha256sums_x86_64=('SKIP')

prepare() {
    echo "Fetching latest Quietly release metadata..."
    local release_json download_url
    release_json="$(curl -fsSL --max-time 20 "${_gh_api}")" || {
        echo "ERROR: Could not fetch latest release from GitHub API."
        return 1
    }

    # Prefer architecture-specific asset names first; then fallback to any AppImage.
    download_url="$(echo "${release_json}" | grep -oP '"browser_download_url"\s*:\s*"\K[^"]+' | grep -E 'x86_64\.AppImage$' | head -n1 || true)"
    if [[ -z "${download_url}" ]]; then
        download_url="$(echo "${release_json}" | grep -oP '"browser_download_url"\s*:\s*"\K[^"]+' | grep -E '\.AppImage$' | head -n1 || true)"
    fi

    if [[ -z "${download_url}" ]]; then
        echo "ERROR: No AppImage asset found in latest release."
        return 1
    fi

    echo "Downloading: ${download_url}"
    curl -fL --progress-bar -o "Quietly.AppImage" "${download_url}" || {
        echo "ERROR: Failed to download AppImage from release asset URL."
        return 1
    }

    chmod +x "Quietly.AppImage"
}

package() {
    install -Dm755 "${srcdir}/Quietly.AppImage" "${pkgdir}/opt/${pkgname}/Quietly.AppImage"

    install -dm755 "${pkgdir}/usr/bin"
    cat > "${pkgdir}/usr/bin/${pkgname}" <<EOF
#!/bin/sh
exec /opt/${pkgname}/Quietly.AppImage "\$@"
EOF
    chmod +x "${pkgdir}/usr/bin/${pkgname}"

    cd "${srcdir}"
    ./Quietly.AppImage --appimage-extract usr/share/icons 2>/dev/null || true
    ./Quietly.AppImage --appimage-extract quietlycode.png  2>/dev/null || true

    if [ -f "squashfs-root/quietlycode.png" ]; then
        install -Dm644 "squashfs-root/quietlycode.png" \
            "${pkgdir}/usr/share/icons/hicolor/512x512/apps/quietlycode.png"
    fi
    rm -rf squashfs-root

    install -dm755 "${pkgdir}/usr/share/applications"
    cat > "${pkgdir}/usr/share/applications/quietlycode.desktop" <<EOF
[Desktop Entry]
Name=Quietly
Comment=Offline-First Local AI IDE
Exec=/opt/${pkgname}/Quietly.AppImage
Icon=quietlycode
Type=Application
Categories=Development;IDE;TextEditor;
Keywords=IDE;AI;Code;Editor;LLM;
StartupWMClass=Quietly
EOF
}
