# Maintainer: Ibrahim Zarar <mibrahimzarar@gmail.com>
pkgname=quietlycode
pkgver=1.0.6
pkgrel=1
pkgdesc="Offline-First Local AI IDE powered by llama.cpp and AirLLM"
arch=('x86_64')
url="https://quietlycode.netlify.app"
license=('custom')
depends=('libnotify' 'libxtst' 'nss' 'libsecret' 'gtk3' 'libxss')
options=(!strip)

_gh="https://github.com/mibrahimzarar/Quietly/releases/latest/download"

source_x86_64=("Quietly.AppImage::${_gh}/Quietly-x64.AppImage")

sha256sums_x86_64=('SKIP')

prepare() {
    chmod +x "Quietly.AppImage"
}

package() {
    install -Dm755 "${srcdir}/Quietly.AppImage" "${pkgdir}/opt/${pkgname}/Quietly.AppImage"

    install -dm755 "${pkgdir}/usr/bin"
    cat > "${pkgdir}/usr/bin/${pkgname}" <<EOF
#!/bin/sh
exec /opt/${pkgname}/Quietly.AppImage "\$@"
EOF
    chmod +x "${pkgdir}/usr/bin/${pkgname}"

    cd "${srcdir}"
    ./Quietly.AppImage --appimage-extract usr/share/icons 2>/dev/null || true
    ./Quietly.AppImage --appimage-extract quietlycode.png  2>/dev/null || true

    if [ -f "squashfs-root/quietlycode.png" ]; then
        install -Dm644 "squashfs-root/quietlycode.png" \
            "${pkgdir}/usr/share/icons/hicolor/512x512/apps/quietlycode.png"
    fi
    rm -rf squashfs-root

    install -dm755 "${pkgdir}/usr/share/applications"
    cat > "${pkgdir}/usr/share/applications/quietlycode.desktop" <<EOF
[Desktop Entry]
Name=Quietly
Comment=Offline-First Local AI IDE
Exec=/opt/${pkgname}/Quietly.AppImage
Icon=quietlycode
Type=Application
Categories=Development;IDE;TextEditor;
Keywords=IDE;AI;Code;Editor;LLM;
StartupWMClass=Quietly
EOF
}
